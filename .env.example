# Copy this file to .env and fill in your values
# The .env file is NOT committed to git (see .gitignore)

# --- Required: at least one cloud provider API key ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# --- Ollama (local models, runs on your Mac) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Cloud model selection ---
# Critics use the cheaper/faster model (Haiku)
# Synthesizer uses the smarter model (Sonnet)
CRITIC_MODEL_CLOUD=claude-haiku-4-5-20251001
SYNTHESIZER_MODEL_CLOUD=claude-sonnet-4-6

# --- Database ---
# For local dev without Docker: make sure PostgreSQL is running locally
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arbitrator

# --- CORS: frontend URL(s) that can call the backend ---
CORS_ORIGINS=http://localhost:3000
